{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Benchmark Upserts",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/test",
            "args": [
                "-d",
                "tmpdir",
                "-m",
                "benchmark-upserts",
                "-t",
                "1000000"
            ],
            "cwd": "${workspaceFolder}",
            "stopOnEntry": false,
            "internalConsoleOptions": "openOnSessionStart",
            "preLaunchTask": "build.fish"
        }
    ]
}