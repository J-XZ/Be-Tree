{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Rust (init_vm)",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "build",
                    "--manifest-path",
                    "xz_scripts/rust_utils/init_vm/Cargo.toml",
                    "--bin",
                    "init_vm"
                ]
            },
            "program": "${cargo:program}",
            "args": [],
            "env": {
                "SHARED_MEM_SIZE_MB": "2048",
                "SHARED_MEM_PATH": "/mnt/xz_shared_mem",
                "SHARED_MEM_NUMA_NODE": "0",
                "VM_NUMA_NODE": "0",
                "VM_CNT": "2",
                "CORE_CNT_PRE_VM": "2",
                "MEM_SIZE_MB_PRE_VM": "3072",
                "VM_STORAGE_PATH": "/mnt/xz_vm_storage",
                "NODE0_IP": "192.168.100.10",
                "BRIDGE_TAP_IP": "192.168.100.1",
                "ENABLE_ADVANCED_SETTING": "false",
                "SRIOV_NIC": "",
                "OUTSIDE_NIC": "",
                "COPY_ROOT_IMG": "false"
            },
            "cwd": "${workspaceFolder}",
            "stopOnEntry": false,
            "initCommands": [
                "process handle -s false -p true -n true SIGTRAP"
            ],
        },
        {
            "name": "debug bash tigon/scripts/run.sh",
            "type": "bashdb",
            "request": "launch",
            "program": "./scripts/run.sh",
            "args": [
                "TPCC",
                "TwoPLPasha",
                "2",
                "2",
                "mixed",
                "10",
                "15",
                "1",
                "0",
                "1",
                "Clock",
                "OnDemand",
                "200000000",
                "1",
                "WriteThrough",
                "None",
                "15",
                "5",
                "GROUP_WAL",
                "20000",
                "0",
                "0"
            ],
            "cwd": "${workspaceFolder}/tigon",
        },
        {
            "name": "Debug bench_tpcc (LLDB) vm0",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/tigon/build/bench_tpcc",
            "args": [
                "--logtostderr=1",
                "--id=0",
                "--servers=192.168.100.2:1234;192.168.100.3:1234",
                "--threads=2",
                "--partition_num=4",
                "--granule_count=2000",
                "--log_path=/root/pasha_log",
                "--lotus_checkpoint=1",
                "--persist_latency=0",
                "--wal_group_commit_time=20000",
                "--wal_group_commit_size=10",
                "--partitioner=hash",
                "--hstore_command_logging=false",
                "--replica_group=1",
                "--lock_manager=0",
                "--batch_flush=1",
                "--lotus_async_repl=true",
                "--batch_size=0",
                "--time_to_run=15",
                "--time_to_warmup=5",
                "--use_cxl_transport=1",
                "--use_output_thread=0",
                "--cxl_trans_entry_struct_size=2048",
                "--cxl_trans_entry_num=8192",
                "--enable_migration_optimization=1",
                "--migration_policy=Clock",
                "--when_to_move_out=OnDemand",
                "--hw_cc_budget=200000000",
                "--enable_scc=1",
                "--scc_mechanism=WriteThrough",
                "--model_cxl_search_overhead=0",
                "--pre_migrate=None",
                "--protocol=TwoPLPasha",
                "--query=mixed",
                "--neworder_dist=10",
                "--payment_dist=15"
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Debug src/cxl_basic/build/test0 (LLDB)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/src/cxl_basic/build/test0",
            "args": [],
            "cwd": "${workspaceFolder}"
        }
    ]
}